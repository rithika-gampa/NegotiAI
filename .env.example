# NegotiAI requires a Postgres database — accounts, products, and deals are
# stored here so they survive server restarts and redeploys.
# Get a free one at https://neon.tech, https://supabase.com, or Render's
# own free Postgres add-on (Render dashboard -> New -> PostgreSQL).
DATABASE_URL=postgres://user:password@host:5432/dbname

# NegotiAI provider chain: Claude primary, falls back to Groq, then Gemini.
# Every negotiation call tries PRIMARY_PROVIDER first; if it fails, it
# automatically retries each entry in BACKUP_PROVIDERS in order, skipping
# any provider whose API key below is left blank.

PRIMARY_PROVIDER=anthropic
BACKUP_PROVIDERS=groq,gemini

ANTHROPIC_API_KEY=your_anthropic_key
ANTHROPIC_MODEL=claude-sonnet-5

GROQ_API_KEY=your_groq_key
GROQ_MODEL=llama-3.3-70b-versatile

GEMINI_API_KEY=your_gemini_key
GEMINI_MODEL=gemini-2.5-flash

PORT=3000

# --- Optional extra backup (leave blank if unused) ---
# XAI_API_KEY=
# XAI_MODEL=grok-4.20-reasoning

# Session cookie signing secret — change this to any random string for real use
SESSION_SECRET=change-me-to-something-random
